# Auth API
NODE_ENV=development
PORT=3000
AUTH_PORT=3000

# Optional: tag when building/pushing the production image
# AUTH_IMAGE=your-registry/auth-service:1.0.0

# Database (local Docker Compose uses DB_HOST=postgres from compose override)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=auth
DB_SYNC=true
DB_LOGGING=false
# Neon / managed Postgres: set DB_SSL=true. Local Postgres (Docker): false
DB_SSL=false

# Redis — local `nest start` / host: point at a running Redis (e.g. `docker compose up -d redis`).
REDIS_URL=redis://localhost:6379
# docker-compose sets REDIS_DOCKER_URL in the app container (do not set REDIS_DOCKER_URL= empty here).
# If `redis://redis:6379` fails in Docker, add docker-compose.override.yml with REDIS_DOCKER_URL=redis://host.docker.internal:6379
# Fly / prod: fly secrets set REDIS_URL="redis://..."

# JWT — use long random strings in production
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Optional: publish ports on host when they conflict
# POSTGRES_PUBLISH_PORT=5432
# REDIS_PUBLISH_PORT=6379
