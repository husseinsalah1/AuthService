# Auth API
NODE_ENV=development
PORT=3000
AUTH_PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_NAME=auth
# Local dev only. Use DB_SYNC=false in production (migrations).
DB_SYNC=true
DB_LOGGING=false
# Neon / managed Postgres: DB_SSL=true. Local Postgres: false.
DB_SSL=false

# Redis — e.g. redis://localhost:6379 or your managed provider URL
REDIS_URL=redis://localhost:6379

# JWT — use long random strings in production
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# Optional: publish ports when they conflict (local tooling)
# POSTGRES_PUBLISH_PORT=5432
# REDIS_PUBLISH_PORT=6379
